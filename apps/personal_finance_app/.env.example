# ====== 应用配置 ======
# 应用名称，用于启动横幅和日志标识。
APP_NAME=personal-finance-app
# 运行环境，可选值：development、test、production。
APP_ENV=development
# 日志目录。相对路径会基于项目根目录解析。
LOG_DIR=logs
# 日志级别，可选值：DEBUG、INFO、WARNING、ERROR、CRITICAL。
LOG_LEVEL=INFO
# 数据目录。相对路径会基于项目根目录解析。
DATA_DIR=data
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# LLM API 的基础 URL (例如 DeepSeek 的 https://api.deepseek.com/v1)
LLM_URL=https://api.openai.com/v1
