# ====== 应用配置 ======
APP_NAME=personal-finance-app
APP_ENV=development
# 日志目录。相对路径会基于项目根目录解析。
LOG_DIR=logs
# 日志级别，可选值：DEBUG、INFO、WARNING、ERROR、CRITICAL。
LOG_LEVEL=INFO
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# LLM API 的基础 URL (例如 DeepSeek 的 https://api.deepseek.com/v1)
LLM_URL=https://api.openai.com/v1
