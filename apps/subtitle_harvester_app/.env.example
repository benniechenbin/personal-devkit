# ====== 应用配置 ======
# 应用名称，用于日志和运行时元数据。
APP_NAME=subtitle-harvester-app
# 运行环境：development、test 或 production。
APP_ENV=development
# 应用日志目录。相对路径会基于应用根目录解析。
LOG_DIR=logs
# 生成候选 JSON 文件的目录。相对路径会基于应用根目录解析。
OUTPUT_DIR=output
# 应用日志级别。
LOG_LEVEL=INFO
# TMDb API Key 或 Read Access Token。密钥值不会写入 .env.example。
TMDB_API_KEY=
# TMDb 响应语言。
TMDB_LANGUAGE=zh-CN
# 电影发现接口使用的 TMDb 地区。
TMDB_REGION=CN
# 每种媒体类型默认抓取的 TMDb 结果页上限。
TMDB_MAX_PAGES=3
# SubDL API Key，用于字幕搜索。
SUBDL_API_KEY=
# SubDL 字幕语言筛选，多个语言用逗号分隔。
SUBDL_LANGUAGES=ZH,ZH-CN,EN
