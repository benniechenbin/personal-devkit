# ====== Application configuration ======
# Application name used in logs and runtime metadata.
APP_NAME=subtitle-harvester-app
# Runtime environment: development, test, or production.
APP_ENV=development
# Directory for application logs. Relative paths resolve from the app root.
LOG_DIR=logs
# Directory for generated candidate JSON files. Relative paths resolve from the app root.
OUTPUT_DIR=output
# Application log level.
LOG_LEVEL=INFO
# TMDb API key or Read Access Token. Secret values are never written to .env.example.
TMDB_API_KEY=
# TMDb response language.
TMDB_LANGUAGE=zh-CN
# TMDb region used for movie discovery.
TMDB_REGION=CN
# Default maximum number of TMDb result pages to fetch per media type.
TMDB_MAX_PAGES=3
