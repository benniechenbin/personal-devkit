# 由 ocr_app.config.settings.Settings 自动生成。
# 请勿在此文件中填写真实密钥。

# 应用名称，用于日志标识。
APP_NAME=ocr-app
# 运行环境，可选值：development、test、production。
APP_ENV=development
# 日志目录。相对路径会基于应用目录解析。
LOG_DIR=logs
# 日志级别，可选值：DEBUG、INFO、WARNING、ERROR、CRITICAL。
LOG_LEVEL=INFO
# 默认文档解析模式，可选值：vector、vision。
DOC_PROCESSING_MODE=vision
# Markdown 和提取资源输出目录。相对路径会基于应用目录解析。
OUTPUT_DIR=output
# 预留模型名称配置。
MODEL_NAME=deepseek-chat
# OpenAI API 密钥。
OPENAI_API_KEY=
# Gemini API 密钥。
GEMINI_API_KEY=
# Tavily API 密钥。
TAVILY_API_KEY=
