# 由 app.config.settings.Settings 自动生成。
# 请勿在此文件中填写真实密钥。

# 应用名称，用于日志与运行时元数据。
APP_NAME=agent-enterprise-boilerplate
# 运行环境，可选值：development、testing、production。
APP_ENV=development
# 日志目录；相对路径基于当前工作目录解析。
LOG_DIR=logs
# 日志级别，例如 DEBUG、INFO、WARNING、ERROR 或 CRITICAL。
LOG_LEVEL=INFO
# 日志格式；auto 在开发环境使用易读格式，在生产环境使用 JSON 格式。
LOG_FORMAT=auto
# 默认模型提供商。
DEFAULT_MODEL_PROVIDER=openai
# 默认模型名称。
MODEL_NAME=gpt-4o-mini
# OpenAI API 密钥。
OPENAI_API_KEY=
# 可选的 OpenAI 兼容 API 基础地址。
OPENAI_API_BASE=
# Anthropic API 密钥。
ANTHROPIC_API_KEY=
# Google 或 Gemini API 密钥；优先使用 GOOGLE_API_KEY。
GOOGLE_API_KEY=
# DeepSeek API 密钥。
DEEPSEEK_API_KEY=
# 可选搜索集成使用的 Tavily API 密钥。
TAVILY_API_KEY=
